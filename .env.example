DATABASE_URL=postgresql://seouser:seopass@localhost:5432/seoforecaster
# Provedor LLM para a expansão (long-tail + content gaps):
#   ollama (default) = local, ilimitado, roda em CPU (sem rate limit) — ideal pra testar
#   groq             = cloud llama-3.3-70b, mais esperto, mas rate-limited no free tier
LLM_PROVIDER=ollama
OLLAMA_EXPAND_MODEL=qwen2.5:3b-instruct
# GROQ_API_KEY só é necessária se LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here
# GDELT (opcional): cole o JSON inteiro da service account numa linha só
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
CHRONOS_SERVICE_URL=http://chronos:8001
OLLAMA_URL=http://ollama:11434
TOP_N_FINALISTS=50
BREAKOUT_THRESHOLD=0.5
